# Add your Stripe secret key and webhook secret here.
# These are required for server-side Stripe operations like creating checkout sessions.
# See https://stripe.com/docs/keys and https://stripe.com/docs/webhooks for more info.
# IMPORTANT: These should NOT be exposed in client-side code.
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Add your Stripe publishable key here.
# This key is safe to expose in client-side code.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
